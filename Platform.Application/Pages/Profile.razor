@page "/profile"

<PageTitle>Профиль</PageTitle>

<h1>Профиль пользователя</h1>

<p class="text-muted">Временная заглушка для выбора роли и ID пользователя.</p>

<div class="mb-3">
    <label class="form-label">ID пользователя (Guid)</label>
    <input class="form-control" @bind="userIdInput" placeholder="Например: 14e8e68f-ec84-4ffb-b7cc-2b813c304af3" />
</div>

<div class="mb-3">
    <label class="form-label">Роль</label>
    <InputSelect class="form-select" @bind-Value="selectedRole">
        <option value="@UserRole.Student">Студент</option>
        <option value="@UserRole.Teacher">Преподаватель</option>
    </InputSelect>
</div>

<button class="btn btn-primary" @onclick="Save">Сохранить</button>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@code {
    [Inject]
    public IUserContextService UserContextService { get; set; } = default!;

    private string userIdInput = string.Empty;
    private UserRole selectedRole = UserRole.Student;
    private string? message;

    protected override void OnInitialized()
    {
        if (UserContextService.Current.UserId is Guid userId)
        {
            userIdInput = userId.ToString();
        }

        selectedRole = UserContextService.Current.Role;
    }

    private void Save()
    {
        var parsed = Guid.TryParse(userIdInput, out var userId);
        UserContextService.SetUser(parsed ? userId : null, selectedRole);

        message = parsed
            ? $"Профиль обновлен. Роль: {selectedRole}, ID: {userId}"
            : $"Профиль обновлен. Роль: {selectedRole}, ID не задан";
    }
}
