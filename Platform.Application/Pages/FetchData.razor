@page "/fetchdata"

<PageTitle>Данные</PageTitle>

<h1>Данные</h1>

@if (UserContextService.Current.Role == UserRole.Student)
{
    <p>Заглушка данных для студента: список курсов и доступные ачивки.</p>
}
else
{
    <p>Заглушка данных для преподавателя: управление курсами и критериями достижений.</p>
}

@code {
    [Inject]
    public IUserContextService UserContextService { get; set; } = default!;
}
